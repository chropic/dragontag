#!/bin/sh
# dragontag versions every commit.
#
# This hook bumps the patch version (via scripts/bump_version.py) and stages the
# result so it lands in the commit you're making. Enable it once per clone with:
#
#     git config core.hooksPath .githooks
#
# See docs/VERSIONING.md. To make a single commit without a bump (rare):
#
#     git commit --no-verify
set -e

root="$(git rev-parse --show-toplevel)"

# Don't bump on a merge commit: the version would just cause a needless
# conflict, and the merge already carries the bumped versions of both sides.
if [ -f "$root/.git/MERGE_HEAD" ]; then
    exit 0
fi

python3 "$root/scripts/bump_version.py" >/dev/null

git add \
    "$root/pyproject.toml" \
    "$root/dragontag/app/__init__.py" \
    "$root/dragontag/__init__.py"
